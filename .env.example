# --- DATABASE CONFIG ---
# PostgreSQL connection string (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/real_estate_crm"

# --- AUTHENTICATION ---
# Random string for JWT signing
JWT_SECRET="your_super_secret_jwt_key_here"

# --- SERVER URLS ---
# Backend Port
PORT=5000
# Frontend API URL (for Vite)
VITE_API_URL="http://localhost:5000/api"

# --- THIRD-PARTY SERVICES (EXTERNAL KEYS) ---
# Email (SendGrid/SMTP)
MAIL_HOST="smtp.sendgrid.net"
MAIL_PORT=587
MAIL_USER="apikey"
MAIL_PASS="your_sendgrid_api_key"

# SMS (Twilio)
TWILIO_ACCOUNT_SID="ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"

# Image Storage (Cloudinary/AWS)
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
# OR AWS_S3_BUCKET="your_bucket_name"

# --- MAPS INTEGRATION ---
GOOGLE_MAPS_API_KEY="your_google_maps_key"
